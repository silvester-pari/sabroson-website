---
import Social from "./Social.astro";
---

<header class="main-header">
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src="/android-chrome-144x144.png" alt="SABROSON Logo" class="nav-logo" />
    </a>
    
    <button class="mobile-menu-toggle" aria-label="Toggle menu">
      ☰
    </button>
    
    <div class="nav-wrapper">
      <nav class="main-nav">
        <ul class="nav-links">
          <li><a href="#about">Band</a></li>
          <li><a href="#events">Live</a></li>
          <li><a href="#media">Media</a></li>
          <li><a href="#contact">Kontakt</a></li>
        </ul>
      </nav>
      
      <div class="nav-social">
        <Social />
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const navWrapper = document.querySelector('.nav-wrapper');
  
  if (toggle && navWrapper) {
    toggle.addEventListener('click', () => {
      navWrapper.classList.toggle('is-active');
    });
  }
</script>

<style>
  .main-header {
    background: var(--sun-yellow);
    border-bottom: var(--border-width) solid var(--ink-black);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0.75rem 1rem;
  }
  
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo-link {
    display: block;
    width: 60px;
    height: 60px;
    transition: transform 0.2s;
    background: var(--ink-black);
    padding: 5px;
    border: var(--border-width) solid var(--ink-black);
    box-shadow: 4px 4px 0px var(--sunset-orange);
    border-radius: 50%;
  }
  
  .logo-link:hover {
    transform: scale(1.05) rotate(-3deg);
    background: var(--sunset-orange);
  }
  
  .nav-logo {
    width: 100%;
    height: auto;
    border: none;
    box-shadow: none;
    transform: none;
    filter: none;
  }
  
  .nav-wrapper {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-links a {
    text-decoration: none;
    font-family: var(--font-headings);
    font-weight: bold;
    font-size: 1.5rem;
    color: var(--ink-black);
    text-transform: uppercase;
    transition: all 0.1s;
    padding: 0.5rem 1rem;
    display: inline-block;
  }
  
  .nav-links a:hover {
    background: var(--sunset-orange);
    color: var(--ink-black);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--ink-black);
    outline: 2px solid var(--ink-black);
  }

  /* Specific hover colors for variety */
  .nav-links li:nth-child(2) a:hover { background: var(--muted-teal); color: var(--paper-white); }
  .nav-links li:nth-child(3) a:hover { background: var(--jungle-green); color: var(--paper-white); }
  .nav-links li:nth-child(4) a:hover { background: var(--deep-terracotta); color: var(--paper-white); }
  
  .nav-social {
    display: flex;
    align-items: center;
  }
  
  .nav-social :global(div) {
    padding: 0 !important;
    margin: 0 !important;
  }
  
  .nav-social :global(a) {
    margin: 0 0.4rem !important;
    transition: transform 0.2s;
    display: inline-block;
  }
  
  .nav-social :global(a:hover) {
    transform: scale(1.2) rotate(5deg);
  }
  
  .nav-social :global(svg) {
    width: 32px !important;
    height: 32px !important;
    fill: var(--black) !important;
    transition: fill 0.2s;
  }
  
  .nav-social :global(a:hover svg) {
    fill: var(--orange) !important;
  }
  
  .mobile-menu-toggle {
    display: none;
    background: var(--black);
    color: var(--white);
    border: 3px solid var(--white);
    font-size: 2rem;
    cursor: pointer;
    padding: 0.2rem 0.6rem;
    transition: all 0.2s;
    font-family: inherit;
  }

  .mobile-menu-toggle:hover {
    background: var(--orange);
    color: var(--black);
    border-color: var(--black);
    transform: scale(1.05);
  }

  @media (max-width: 850px) {
    .mobile-menu-toggle {
      display: block;
    }
    
    .nav-wrapper {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      box-sizing: border-box;
      background: var(--sun-yellow);
      border-bottom: var(--border-width) solid var(--ink-black);
      flex-direction: column;
      padding: 2rem;
      gap: 2rem;
      box-shadow: 0 8px 0px var(--ink-black);
    }
    
    .nav-wrapper.is-active {
      display: flex;
    }
    
    .nav-links {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      width: 100%;
    }
    
    .nav-links a {
      display: block;
      font-size: 1.5rem;
    }
    
    .nav-social {
      justify-content: center;
      width: 100%;
    }
  }
</style>
