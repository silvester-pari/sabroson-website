<style>
  .impressum-container {
    max-width: 800px;
    margin: 4rem auto;
    padding: 3rem 1.5rem;
    background-color: var(--paper-white);
    border: var(--border-width) solid var(--ink-black);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0px var(--sunset-orange);
    color: var(--ink-black);
    transform: rotate(0.5deg);
    width: calc(100% - 2rem);
    box-sizing: border-box;
  }

  h2 {
    font-family: var(--font-headings);
    text-transform: uppercase;
    font-size: 3rem;
    border-bottom: var(--border-width) solid var(--ink-black);
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }

  h3 {
    font-family: var(--font-headings);
    font-size: 1.8rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--deep-terracotta);
    text-transform: uppercase;
  }

  p, li {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    font-family: var(--font-body);
  }

  ul {
    list-style-type: none;
    padding-left: 0;
  }
  
  li {
    border-left: 4px solid var(--sun-yellow);
    padding-left: 1rem;
  }

  a {
    color: var(--ink-black);
    font-weight: bold;
    text-decoration: none;
    border-bottom: 3px solid var(--sun-yellow);
    transition: all 0.1s;
  }

  a:hover {
    color: var(--ink-black);
    background-color: var(--sun-yellow);
    border-bottom-color: var(--ink-black);
  }
</style>